# KIS OpenAPI (모의투자) — 실제 값은 .env에만 작성하고 커밋하지 말 것
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_ENV=vps

# TimescaleDB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mahdi
DB_USER=mahdi
DB_PASSWORD=mahdi

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Slack 알림 (2026-07-19, 운영점검보고서 §5-4) — 실제 값은 .env에만 작성하고 커밋하지 말 것
